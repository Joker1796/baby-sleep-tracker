# Авто-инкремент патч-версии (третье число) + номеров сборки на каждом коммите.
# Если версия в этом коммите уже поднята вручную (npm run bump:minor|major) и
# застейджена — авто-патч пропускаем, чтобы релизный коммит остался ровно на
# 1.x.0 / x.0.0, а не 1.x.1.
if git diff --cached -- app.json | grep -qE '^\+[^+].*"version"'; then
  echo "husky: версия уже изменена в этом коммите — авто-патч пропущен."
else
  node scripts/bump-version.mjs patch
fi
